# Copy this file to .env and fill in real values before running docker compose.
JWT_KEY=change-me-to-a-long-random-secret-before-running

# Required: PostgreSQL connection string for the API.
# For docker-compose local dev this points to the postgres service defined below.
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=fishytodo;Username=postgres;Password=change-me
