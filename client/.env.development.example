# Copy to `.env.development.local` to override local dev defaults (git-ignored: *.local).

# Where the ASP.NET API runs locally (dotnet run default: http://localhost:5112)
VITE_API_BASE_URL=http://localhost:5112

# Role passed to POST /token for the demo JWT (VISITOR | WRITER | ADMIN)
VITE_DEMO_JWT_ROLE=ADMIN

# Optional — visible app name (default: FishyToDo — use FishyTODO for all-caps)
# VITE_APP_TITLE=FishyToDo
